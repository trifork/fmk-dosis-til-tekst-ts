{
    "include": [
        "src/main/ts",
        "src/test/**/*.ts"
    ],
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "declaration": true,
        "rootDir": ".",
        "outDir": "target/tsc",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "types": [
            "mocha",
            "node"
        ]
    }
}